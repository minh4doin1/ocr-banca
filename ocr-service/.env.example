# ============================================================
# OCR Service Configuration
# ============================================================

# --- Server ---
HOST=0.0.0.0
PORT=8100

# --- Storage ---
# Thư mục lưu file upload và kết quả
STORAGE_DIR=./storage

# --- OCR Engine ---
# Chọn engine: "paddle_vietocr" (recommended) hoặc "tesseract"
OCR_ENGINE=paddle_vietocr

# PaddleOCR settings
# Máy host GPU (RTX 2070): true + chạy scripts/setup_gpu_windows.ps1
# Máy client/seller: false (CPU hoặc proxy sang GPU nội bộ)
PADDLE_USE_GPU=false
PADDLE_LANG=vi

# --- Máy HOST GPU (worker nội bộ) ---
# Bật token để máy seller kết nối an toàn qua LAN
# REMOTE_WORKER_TOKEN=your-secret-token-here
#
# Trên máy HOST GPU (1 máy — user chỉ cần mở link LAN/Tailscale):
# PADDLE_USE_GPU=true  → option "GPU nội bộ" tự bật, không cần set INTERNAL_GPU_URL
#
# Trên máy CLIENT (proxy sang worker khác):
# INTERNAL_GPU_URL=http://192.168.1.100:8100
# INTERNAL_GPU_TOKEN=your-secret-token-here

# VietOCR settings
VIETOCR_MODEL=vgg_transformer
# Các model có sẵn: vgg_transformer, vgg_seq2seq

# --- PDF Processing ---
# DPI khi chuyển PDF → image (250 = nhanh; 300 = chi tiết hơn)
PDF_DPI=250
PDF_LAZY_CONVERT=true
PDF_PREFETCH_PAGES=false
POPPLER_THREAD_COUNT=4
# Hàng đợi multi-user (2 worker — 2 job song song trên host GPU)
OCR_QUEUE_MAX_SIZE=30
OCR_WORKER_THREADS=2
OCR_WARMUP_ON_STARTUP=true
OCR_PAGE_PIPELINE=true
VIETOCR_BATCH_SIZE=32
TORCH_NUM_THREADS=4
CELL_INK_MIN_RATIO=0.015
VIETOCR_GPU_SUBPROCESS=true
# Đường dẫn đến thư mục poppler/bin (Dành cho Windows nếu chưa cài PATH hệ thống, ví dụ: C:/poppler/bin)
POPPLER_PATH=D:/Agribank/banca/ocr-release-personal/ocr-service/bin/poppler-24.08.0/Library/bin

# --- Confidence Threshold ---
# Cell có confidence dưới ngưỡng sẽ được highlight để review
OCR_CONFIDENCE_THRESHOLD=0.85

# --- CORS ---
# Origins được phép gọi API (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Logging ---
LOG_LEVEL=INFO

# --- Remote OCR Worker ---
# Máy GPU nội bộ (worker) — chạy ocr-service với PADDLE_USE_GPU=true
# Máy client (seller) — trỏ tới URL worker để proxy OCR
INTERNAL_GPU_URL=
INTERNAL_GPU_TOKEN=

# Token bảo vệ worker (đặt trên cả worker GPU và Colab notebook)
REMOTE_WORKER_TOKEN=
REMOTE_POLL_INTERVAL_SECONDS=1.5
REMOTE_REQUEST_TIMEOUT_SECONDS=120

# ============================================================
# Keycloak — Tạo lô User (Admin REST API + Service Account)
# ============================================================
# Map từ FE dev (.env Vite):
#   VITE_KEYCLOAK_URL          -> KEYCLOAK_BASE_URL, BANCA_CORE_KC_BASE_URL
#   VITE_KEYCLOAK_REALM        -> KEYCLOAK_REALM, BANCA_CORE_KC_REALM
#   VITE_KEYCLOAK_CLIENT_ACCESS_ID -> KEYCLOAK_ROLES_CLIENT_ID (client chứa role banca-*)
#   VITE_KEYCLOAK_CLIENT_ID=banca-client là SPA client, KHÔNG dùng cho provisioning.
# Dùng Confidential Client + Service Account riêng (vd keycloak-automation).
# Gán role realm-management: manage-users, view-users, view-clients.

# URL gốc Keycloak (VITE_KEYCLOAK_URL), không có dấu "/" ở cuối
KEYCLOAK_BASE_URL=http://10.63.29.141:8080
KEYCLOAK_REALM=agribank
# Service account client (tạo user — khác banca-client SPA)
KEYCLOAK_CLIENT_ID=keycloak-automation
KEYCLOAK_CLIENT_SECRET=iU2L49gZ0pJc1bU07N4hEgpM015SibSs
# Client chứa role banca-* (VITE_KEYCLOAK_CLIENT_ACCESS_ID=banca)
KEYCLOAK_ROLES_CLIENT_ID=banca
# Xác thực chứng chỉ TLS (đặt false nếu dùng self-signed nội bộ)
KEYCLOAK_VERIFY_SSL=true
KEYCLOAK_TIMEOUT_SECONDS=30
KEYCLOAK_TOKEN_LEEWAY_SECONDS=30

# Mặc định nghiệp vụ khi tạo/reset user
KEYCLOAK_DEFAULT_TEMPORARY=true
KEYCLOAK_DEFAULT_REQUIRED_ACTIONS=UPDATE_PASSWORD,CONFIGURE_TOTP
# Mật khẩu tạm mặc định theo SOP manual
KEYCLOAK_DEFAULT_TEMP_PASSWORD=Agribank@123

# Map vai trò nghiệp vụ -> client role Keycloak
KEYCLOAK_ROLE_MAP=quản trị:banca-admin;đại lý viên:banca-seller;kế toán viên:banca-accounting-operator;phê duyệt viên:banca-accounting-controller;banca-admin:banca-admin;banca-seller:banca-seller;banca-accounting-operator:banca-accounting-operator;banca-accounting-controller:banca-accounting-controller

# Map field -> Keycloak attribute key
KEYCLOAK_ATTRIBUTE_MAP=cccd:cccd;name:fullName;branch_code:branchCode;agent_code:agentCode;branch_name:branchName;department_name:departmentName;ipcas_code:ipcasCode;phone:phoneNumber;unit_code:unitCode

# Map tiêu đề cột Excel/OCR -> field Keycloak.
KEYCLOAK_HEADER_MAP=username:tên đăng nhập|username|user;email:email|thư điện tử;name:họ tên|hoten;first_name:tên;last_name:họ;cccd:cccd|căn cước|cmnd;branch_code:mã chi nhánh|mã cn;ipcas_code:mã ipcas|ipcas|user ipcas;phone:số điện thoại|sdt|phone;unit_code:mã đơn vị|ma don vi;role:vai trò|role|quyền;agent_code:mã đại lý|mã đl;password:mật khẩu|password

# Trường bắt buộc theo SOP manual (comma-separated)
USER_REQUIRED_FIELDS=email,first_name,last_name,branch_code,ipcas_code,cccd,phone,unit_code,role

# ============================================================
# Banca Core — Enrich mã chi nhánh / đại lý
# ============================================================
# Map từ FE dev:
#   VITE_BANCA_HOST=http://10.63.29.141:41809/api/v1
#     -> BANCA_CORE_URL=http://10.63.29.141:41809  (backend tự thêm /api/v1/...)
#   VITE_KEYCLOAK_URL / REALM -> BANCA_CORE_KC_*
# BANCA_CORE_KC_CLIENT_ID/SECRET: service account gọi API banca (vd banca-seller), điền secret thật.
BANCA_CORE_ENABLED=true
BANCA_CORE_URL=http://10.63.29.141:41809
BANCA_CORE_KC_BASE_URL=http://10.63.29.141:8080
BANCA_CORE_KC_REALM=agribank
BANCA_CORE_KC_CLIENT_ID=banca-seller
BANCA_CORE_KC_CLIENT_SECRET=
BANCA_CORE_VERIFY_SSL=true
BANCA_CORE_TIMEOUT_SECONDS=30
BANCA_CORE_MATCH_THRESHOLD=0.85
BANCA_CORE_MATCH_SUGGEST_THRESHOLD=0.65
BANCA_CORE_MATCH_MIN_GAP=0.08
