# ============================================================
# OCR Service — PRODUCTION (chỉ phần user Keycloak + env switch)
# Copy thành .env trên server OCR production, điền secret thật.
# ============================================================

APP_ENV=prod
HOST=0.0.0.0
PORT=8100

# FE dev (localhost:5173) chuyển sang PROD cần origin này trong CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,https://<host-fe-prod>

# URL cho nút chuyển môi trường trên FE
OCR_ENV_DEV_API_URL=http://<host-dev>:8100
OCR_ENV_PROD_API_URL=https://<host-ocr-prod>
OCR_ENV_DEV_LABEL=DEV
OCR_ENV_PROD_LABEL=PROD

# --- Keycloak PROD (tạo user / reset MK-OTP) ---
KEYCLOAK_BASE_URL=https://admin-sso.agribank.com
KEYCLOAK_REALM=agribank
KEYCLOAK_CLIENT_ID=keycloak-automation
KEYCLOAK_CLIENT_SECRET=iU2L49gZ0pJc1bU07N4hEgpM015SibSs
KEYCLOAK_ROLES_CLIENT_ID=banca
KEYCLOAK_VERIFY_SSL=true

KEYCLOAK_DEFAULT_TEMPORARY=true
KEYCLOAK_DEFAULT_REQUIRED_ACTIONS=UPDATE_PASSWORD,CONFIGURE_TOTP
KEYCLOAK_DEFAULT_TEMP_PASSWORD=Agribank@123

# Không enrich chi nhánh qua Banca Core
BANCA_CORE_ENABLED=false
