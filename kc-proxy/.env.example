# ── Server ──
HOST=0.0.0.0
PORT=8200
LOG_LEVEL=INFO

# ── Keycloak (cluster-internal DNS — KHÔNG đổi thành public URL) ──
KEYCLOAK_INTERNAL_URL=http://keycloak.keycloak.svc.cluster.local:8080
KEYCLOAK_REALM=agribank
KEYCLOAK_CLIENT_ID=ocr-banca-service
KEYCLOAK_CLIENT_SECRET=replace-with-real-secret
KEYCLOAK_VERIFY_SSL=false
KEYCLOAK_TIMEOUT_SECONDS=30
KEYCLOAK_TOKEN_LEEWAY_SECONDS=30

# ── Proxy auth ──
# 256-bit random, share với OCR service qua K8s Secret
PROXY_API_KEY=replace-with-256-bit-random

# ── Path lách (KHÔNG đổi nếu OCR service đang dùng) ──
PROXY_PATH_PREFIX=/api/v1/iam-bridge

# ── Audit ──
AUDIT_LOG_ENABLED=true