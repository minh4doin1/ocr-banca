# ── Server ──
HOST=0.0.0.0
PORT=8300
LOG_LEVEL=info
NODE_ENV=production

# ── Keycloak (cluster-internal DNS) ──
KEYCLOAK_INTERNAL_URL=http://keycloak.keycloak.svc.cluster.local:8080
KEYCLOAK_REALM=agribank
KEYCLOAK_CLIENT_ID=keycloak-automation
KEYCLOAK_CLIENT_SECRET=replace-with-real-secret
KEYCLOAK_VERIFY_SSL=false
KEYCLOAK_TIMEOUT_MS=30000

# ── Auth (caller ↔ user-service) ──
# 256-bit random; share với caller qua K8s Secret
SERVICE_API_KEY=replace-with-256-bit-random

# ── Default client chứa role nghiệp vụ ──
ROLES_CLIENT_ID=banca